# Gemini API key — get one at https://aistudio.google.com/
GEMINI_API_KEY=

# Gemini model to use (default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Google Places API key — enables the search_places tool
# Get one at https://console.cloud.google.com/ (Places API New)
# GOOGLE_PLACES_API_KEY=

# PostgreSQL connection string — enables long-term memory
# Start with: docker compose up -d
DATABASE_URL=postgres://god:god@localhost:5432/god

# WhatsApp session storage path (default: data/whatsapp)
# WHATSAPP_STORE_PATH=data/whatsapp
